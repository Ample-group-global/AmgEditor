{
    "name": "@amplecapitalglobal/editor",
    "version": "1.0.8",
    "type": "module",
    "license": "MIT",
    "description": "A Notion-like block editor component for React",
    "keywords": [
        "editor",
        "notion",
        "block-editor",
        "rich-text",
        "react",
        "typescript"
    ],
    "author": "Ample Capital Global",
    "repository": {
        "type": "git",
        "url": "https://github.com/amplecapitalglobal/editor"
    },
    "main": "./dist/index.cjs",
    "module": "./dist/index.mjs",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.mjs",
            "require": "./dist/index.cjs"
        },
        "./styles": "./dist/style.css",
        "./dist/style.css": "./dist/style.css"
    },
    "files": [
        "dist",
        "README.md",
        "LICENSE",
        "package.json"
    ],
    "sideEffects": [
        "**/*.css",
        "./dist/style.css"
    ],
    "scripts": {
        "build:css": "npx tailwindcss -i client/src/index.css -o dist/public/style.css",
        "dev": "npx concurrently \"npx esbuild client/src/main.tsx --bundle --jsx=automatic --outfile=dist/public/index.js --loader:.tsx=tsx --loader:.ts=ts --alias:@=client/src --sourcemap --watch\" \"npx tsx watch server/index.ts\"",
        "build": "node scripts/build.js",
        "start": "node dist/index.js",
        "check": "tsc --noEmit",
        "format": "prettier --write ."
    },
    "peerDependencies": {
        "react": "^18.0.0 || ^19.0.0",
        "react-dom": "^18.0.0 || ^19.0.0"
    },
    "dependencies": {
        "@dnd-kit/core": "^6.3.1",
        "@dnd-kit/sortable": "^10.0.0",
        "@dnd-kit/utilities": "^3.2.2",
        "@radix-ui/react-alert-dialog": "^1.1.15",
        "@radix-ui/react-avatar": "^1.1.10",
        "@radix-ui/react-dialog": "^1.1.15",
        "@radix-ui/react-dropdown-menu": "^2.1.16",
        "@radix-ui/react-label": "^2.1.7",
        "@radix-ui/react-popover": "^1.1.15",
        "@radix-ui/react-progress": "^1.1.7",
        "@radix-ui/react-scroll-area": "^1.2.10",
        "@radix-ui/react-separator": "^1.1.7",
        "@radix-ui/react-slot": "^1.2.3",
        "@radix-ui/react-switch": "^1.2.6",
        "@radix-ui/react-tabs": "^1.1.13",
        "@radix-ui/react-tooltip": "^1.2.8",
        "class-variance-authority": "^0.7.1",
        "clsx": "^2.1.1",
        "express": "^5.2.1",
        "lucide-react": "^0.453.0",
        "next-themes": "^0.4.6",
        "re-resizable": "^6.11.2",
        "sonner": "^2.0.7",
        "tailwind-merge": "^3.3.1"
    },
    "devDependencies": {
        "@tailwindcss/cli": "^4.2.1",
        "@types/express": "4.17.21",
        "@types/node": "^24.7.0",
        "@types/react": "^19.2.1",
        "@types/react-dom": "^19.2.1",
        "esbuild": "^0.25.0",
        "prettier": "^3.6.2",
        "tailwindcss": "^4.1.14",
        "tsx": "^4.19.1",
        "tw-animate-css": "^1.4.0",
        "typescript": "5.6.3"
    }
}